---
import { getEmDashEntry, type MediaValue } from 'emdash';
import { PortableText } from 'emdash/ui';
import BlogPost from '../../layouts/BlogPost.astro';

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect('/404');
}

const { entry: post } = await getEmDashEntry('posts', slug);

if (!post) {
	return Astro.redirect('/404');
}

function getMediaSrc(image: MediaValue | null | undefined): string | undefined {
	if (!image) return undefined;
	if (image.src) return image.src;
	return `/_emdash/api/media/file/${image.id}`;
}

const featuredImage = post.data.featured_image as MediaValue | null | undefined;
---

<BlogPost
	title={post.data.title}
	description={post.data.excerpt ?? ''}
	pubDate={post.data.publishedAt ?? new Date()}
	updatedDate={post.data.updatedAt}
	heroImage={getMediaSrc(featuredImage)}
>
	<PortableText value={post.data.content} />
</BlogPost>
